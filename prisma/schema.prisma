// ============================================
// AUTONOMOUS AI TUTOR MODELS
// ============================================

model TutorSession {
  id        String @id @default(cuid())
  studentId String
  classId   String
  subject   String
  topic     String
  mode      String // "teach", "practice", "quiz", "revise"

  // Session state
  currentStep Int     @default(0)
  totalSteps  Int     @default(5)
  progress    Int     @default(0) // 0-100
  isCompleted Boolean @default(false)

  // Conversation tracking
  last10Messages  Json // Array of last 10 messages
  currentQuestion Json? // Current question being asked
  questionsAsked  Int   @default(0)
  correctAnswers  Int   @default(0)
  hintsGiven      Int   @default(0)

  // Performance
  timeSpent Int @default(0) // Seconds
  xpEarned  Int @default(0)

  // Metadata
  lessonPlanId   String?
  schemeOfWorkId String?
  metadata       Json? // Additional context

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  @@index([studentId, classId])
  @@index([studentId, subject])
  @@index([isCompleted])
  @@map("tutor_sessions")
}

model ClassSchedule {
  id        String @id @default(cuid())
  classId   String
  schoolId  String
  teacherId String

  // Schedule details
  dayOfWeek Int // 0 = Sunday, 1 = Monday, etc.
  startTime String // "09:00" format
  endTime   String // "10:00" format
  subject   String

  // Optional details
  room     String?
  notes    String?
  isActive Boolean @default(true)

  // Recurrence
  recurring Boolean   @default(true)
  startDate DateTime // When this schedule starts
  endDate   DateTime? // When this schedule ends (optional)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([classId, dayOfWeek])
  @@index([schoolId])
  @@map("class_schedules")
}

model TutorQuestion {
  id         String @id @default(cuid())
  subject    String
  topic      String
  grade      String
  difficulty String // "easy", "medium", "hard"

  // Question content
  questionType  String // "mcq", "short_answer", "fill_blank", "true_false"
  questionText  String @db.Text
  options       Json? // For MCQ
  correctAnswer String @db.Text
  explanation   String @db.Text

  // Metadata
  hints          Json? // Array of hints
  commonMistakes Json? // Array of common mistakes
  relatedTopics  String[] // Related topics

  // AI generation
  isAIGenerated Boolean @default(true)
  generatedBy   String? // User ID who generated/approved

  // Usage tracking
  timesAsked   Int @default(0)
  timesCorrect Int @default(0)
  averageTime  Int @default(0) // Average time to answer in seconds

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([subject, topic, difficulty])
  @@index([grade, subject])
  @@map("tutor_questions")
}

enum TutorMode {
  TEACH
  PRACTICE
  QUIZ
  REVISE
  ASSESSMENT
}

enum QuestionType {
  MCQ
  SHORT_ANSWER
  FILL_BLANK
  TRUE_FALSE
  MATCHING
  ORDERING
}

enum DifficultyLevel {
  EASY
  MEDIUM
  HARD
  EXPERT
}

// ============================================
// CURRICULUM & COURSE MODELS
// ============================================

enum CurriculumType {
  CBC // Kenya Competency-Based Curriculum
  CAMBRIDGE
  IGCSE
  IB
  OTHER
}

enum CourseType {
  // CBC-Based Courses
  CBC_ENGLISH
  CBC_MATH
  CBC_SCIENCE
  CBC_SOCIAL_STUDIES
  CBC_KISWAHILI
  CBC_RELIGIOUS_EDUCATION
  CBC_CREATIVE_ARTS
  CBC_PHYSICAL_EDUCATION

  // Coding & Tech Courses
  CODING_SCRATCH
  CODING_WEB_DEV
  CODING_AI_FOR_KIDS
  CODING_PYTHON

  // Robotics & Engineering
  ROBOTICS_BASIC
  ROBOTICS_ADVANCED

  // Other
  OTHER
}

// Curriculum Model: Represents a full curriculum (e.g., CBC Grade 7)
model Curriculum {
  id          String         @id @default(cuid())
  name        String // e.g., "CBC Grade 7"
  type        CurriculumType @default(CBC)
  grade       String
  description String?
  isActive    Boolean        @default(true)
  schoolId    String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  // Relationships
  school  School?            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  strands CurriculumStrand[]
  courses Course[]

  @@index([type, grade])
  @@map("curriculums")
}

// Curriculum Strand: A major strand in the curriculum (e.g., "Numbers" in CBC Math)
model CurriculumStrand {
  id           String  @id @default(cuid())
  curriculumId String
  name         String // e.g., "Numbers"
  description  String?
  order        Int     @default(0)

  // Relationships
  curriculum Curriculum            @relation(fields: [curriculumId], references: [id], onDelete: Cascade)
  substrands CurriculumSubstrand[]

  @@map("curriculum_strands")
}

// Curriculum Substrand: A sub-topic within a strand (e.g., "Whole Numbers" under "Numbers")
model CurriculumSubstrand {
  id          String  @id @default(cuid())
  strandId    String
  name        String // e.g., "Whole Numbers"
  description String?
  order       Int     @default(0)

  // Relationships
  strand  CurriculumStrand   @relation(fields: [strandId], references: [id], onDelete: Cascade)
  lessons CurriculumLesson[]

  @@map("curriculum_substrands")
}

// Curriculum Lesson: A single lesson within a substrand
model CurriculumLesson {
  id          String   @id @default(cuid())
  substrandId String
  title       String
  content     String? // JSON content for the lesson
  objectives  String[]
  duration    Int? // in minutes
  order       Int      @default(0)
  isCompleted Boolean  @default(false)

  // Relationships
  substrand CurriculumSubstrand @relation(fields: [substrandId], references: [id], onDelete: Cascade)

  @@map("curriculum_lessons")
}

// Course Model: Represents a course (e.g., "Web Development for Grade 7", "CBC Math Grade 8")
model Course {
  id           String          @id @default(cuid())
  title        String
  description  String?
  type         CourseType      @default(OTHER)
  gradeLevel   String
  difficulty   DifficultyLevel @default(EASY)
  duration     String? // e.g., "12 weeks"
  objectives   String[]
  isActive     Boolean         @default(true)
  schoolId     String?
  curriculumId String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  // Relationships
  school             School?                   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  curriculum         Curriculum?               @relation(fields: [curriculumId], references: [id], onDelete: SetNull)
  assignments        CourseAssignment[]
  lessons            CourseLesson[]
  enrollments        CourseEnrollment[]
  teacherAssignments TeacherCourseAssignment[]

  @@index([type, gradeLevel])
  @@map("courses")
}

// Course Lesson: A lesson within a course
model CourseLesson {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  description String?
  content     String? // JSON content for the lesson
  order       Int      @default(0)
  duration    Int? // in minutes
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relationships
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@map("course_lessons")
}

// Course Assignment: An assignment tied to a course
model CourseAssignment {
  id           String @id @default(cuid())
  courseId     String
  assignmentId String
  order        Int    @default(0)

  // Relationships
  course     Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@unique([courseId, assignmentId])
  @@map("course_assignments")
}

// Teacher Course Assignment: Assigns teachers to courses
model TeacherCourseAssignment {
  id         String   @id @default(cuid())
  teacherId  String
  courseId   String
  isPrimary  Boolean  @default(false) // Is this the primary teacher for the course?
  assignedAt DateTime @default(now())

  // Relationships
  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  course  Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([teacherId, courseId])
  @@map("teacher_course_assignments")
}

// Course Enrollment: Enrolls students in courses
model CourseEnrollment {
  id         String   @id @default(cuid())
  studentId  String
  courseId   String
  enrolledAt DateTime @default(now())
  progress   Int      @default(0) // 0-100
  status     String   @default("ACTIVE") // ACTIVE, COMPLETED, DROPPED

  // Relationships
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course  Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId])
  @@map("course_enrollments")
}

// Learning Area: Represents a learning area/subject in the curriculum
model LearningArea {
  id          String   @id @default(cuid())
  name        String
  description String?
  schoolId    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relationships
  school School? @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@map("learning_areas")
}

// ============================================
// INTEGRATION & INFRASTRUCTURE MODELS
// ============================================

// Model for external database connections
model ExternalDatabase {
  id          String        @id @default(cuid())
  name        String
  type        DatabaseType  @default(POSTGRESQL)
  host        String
  port        Int
  database    String
  username    String
  password    String
  ssl         Boolean       @default(true)
  isActive    Boolean       @default(true)
  description String?
  config      Json? // Additional database-specific config
  lastTested  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([type])
  @@map("external_databases")
}

enum DatabaseType {
  POSTGRESQL
  MYSQL
  MONGODB
  SQLSERVER
  REDIS
  OTHER
}

// Email/SMS service configuration
model CommunicationService {
  id           String             @id @default(cuid())
  name         String
  type         CommunicationType
  provider     CommunicationProvider
  apiKey       String?
  apiSecret    String?
  fromEmail    String?
  fromPhone    String?
  isActive     Boolean            @default(true)
  config       Json?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@map("communication_services")
}

enum CommunicationType {
  EMAIL
  SMS
  BOTH
}

enum CommunicationProvider {
  SENDGRID
  MAILGUN
  POSTMARK
  TWILIO
  AFRICASTALKING
  NEXMO
  OTHER
}

// Model for Redis configuration
model RedisConfig {
  id        String        @id @default(cuid())
  name      String
  host      String
  port      Int
  username  String?
  password  String?
  db        Int           @default(0)
  ssl       Boolean       @default(true)
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@map("redis_configs")
}
